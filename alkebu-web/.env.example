# Alkebulan Images Frontend - Local Development Configuration
# Copy this to .env.local and update values for local development

# Site Configuration (Local Development)
PUBLIC_SITE_URL=http://localhost:5173
PUBLIC_ASSET_BASE=/
PUBLIC_SITE_NAME=Alkebulan Images

# Payload CMS Backend (Local Development)
PAYLOAD_API_URL=http://localhost:3000
PAYLOAD_API_KEY=your-payload-api-key-here
# Note: The API key is optional for local development when backend runs without auth

# OAuth Providers (Optional for local development)
# OAuth is handled by Payload backend - these credentials are set in alkebu-load/.env
# Frontend just needs to know the Payload API URL above

# Cloudflare Configuration (Production only - not needed for local dev)
# CF_ZONE_ID=your-cloudflare-zone-id
# CF_API_TOKEN=your-cloudflare-api-token

# Production overrides (uncomment for production)
# PUBLIC_SITE_URL=https://alkebulanimages.com
# PAYLOAD_API_URL=https://api.alkebulanimages.com